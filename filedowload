private static void processName(HttpClient client, String name) throws Exception {
    String url = BASE_URL + name;
    System.out.println("  → GET " + url);

    HttpRequest request = HttpRequest.newBuilder()
            .uri(URI.create(url))
            .header("Authorization", "Bearer " + JWT_TOKEN)
            .header("Accept", "*/*")
            .GET()
            .build();

    // Use InputStream body handler to support streaming large files (e.g. 120MB WAV)
    HttpResponse<InputStream> response = client.send(
            request,
            HttpResponse.BodyHandlers.ofInputStream()
    );

    int statusCode = response.statusCode();
    System.out.println("  → HTTP Status: " + statusCode);

    if (statusCode != 200) {
        // Drain and close the stream on error
        response.body().close();
        throw new RuntimeException("Non-200 response: HTTP " + statusCode);
    }

    // Detect file type from Content-Type header
    String contentType = response.headers()
            .firstValue("Content-Type")
            .orElse("")
            .toLowerCase();

    System.out.println("  → Content-Type: " + contentType);

    String extension = resolveExtension(contentType, name);
    if (extension == null) {
        response.body().close();
        throw new RuntimeException("Unknown Content-Type [" + contentType + "] and cannot infer extension from name.");
    }

    // Strip any existing extension from name before saving
    String baseName = name.replaceAll("(?i)\\.(json|wav)$", "");
    Path outputPath = Path.of(OUTPUT_DIR, baseName + extension);

    // Stream response body directly to disk — avoids loading 120MB into memory
    streamToFile(response.body(), outputPath);

    long fileSizeMB = Files.size(outputPath) / (1024 * 1024);
    System.out.println("  ✓ Saved: " + outputPath.toAbsolutePath() + " (" + fileSizeMB + " MB)");
}

/**
 * Streams the InputStream directly to a file using buffered chunks.
 * This avoids loading the entire file (e.g. 120MB WAV) into memory.
 */
private static void streamToFile(InputStream inputStream, Path outputPath) throws IOException {
    try (InputStream in = new BufferedInputStream(inputStream, BUFFER_SIZE);
         OutputStream out = new BufferedOutputStream(new FileOutputStream(outputPath.toFile()), BUFFER_SIZE)) {

        byte[] buffer = new byte[BUFFER_SIZE];
        int bytesRead;
        long totalBytes = 0;

        while ((bytesRead = in.read(buffer)) != -1) {
            out.write(buffer, 0, bytesRead);
            totalBytes += bytesRead;

            // Print progress every 10MB
            if (totalBytes % (10 * 1024 * 1024) < BUFFER_SIZE) {
                System.out.println("  ↓ Downloaded: " + (totalBytes / (1024 * 1024)) + " MB...");
            }
        }

        out.flush();
    }
}

/**
 * Resolves the file extension from Content-Type header.
 * Falls back to checking the name suffix if Content-Type is ambiguous.
 */
private static String resolveExtension(String contentType, String name) {
    // Check Content-Type first
    if (contentType.contains("application/json") || contentType.contains("text/json")) {
        return ".json";
    }
    if (contentType.contains("audio/wav") || contentType.contains("audio/x-wav")
            || contentType.contains("audio/wave") || contentType.contains("audio/vnd.wave")) {
        return ".wav";
    }

    // Fallback: infer from name suffix
    String lowerName = name.toLowerCase();
    if (lowerName.endsWith(".json")) return ".json";
    if (lowerName.endsWith(".wav"))  return ".wav";

    // Unknown
    return null;
}
